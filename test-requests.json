[
  {
    "name": "Auth - Register",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/register",
    "body": {
      "name": "Alice Example",
      "email": "alice@example.com",
      "password": "Password123!"
    },
    "notes": "On success, backend also sets HTTP-only accessToken and refreshToken cookies."
  },
  {
    "name": "Auth - Login",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/login",
    "body": {
      "email": "alice@example.com",
      "password": "Password123!"
    },
    "notes": "On success, backend also sets HTTP-only accessToken and refreshToken cookies."
  },
  {
    "name": "Auth - Me (requires Bearer token)",
    "method": "GET",
    "url": "http://localhost:3000/api/auth/me",
    "headers": {
      "Authorization": "Bearer <ACCESS_TOKEN> (optional if cookies are sent)"
    },
    "notes": "If cookies are included (withCredentials), Authorization header can be omitted."
  },
  {
    "name": "Auth - Refresh Token",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/refresh-token",
    "body": {
      "refreshToken": "<REFRESH_TOKEN (optional when using cookies)>"
    },
    "notes": "If refreshToken cookie is present, body field is optional."
  },
  {
    "name": "Auth - Logout",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/logout",
    "notes": "Clears accessToken and refreshToken cookies on the client."
  },
  {
    "name": "Auth - Verify Email",
    "method": "GET",
    "url": "http://localhost:3000/api/auth/verify-email?token=<VERIFICATION_TOKEN>"
  },
  {
    "name": "Auth - Resend Verification Email",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/resend-verification",
    "body": {
      "email": "alice@example.com"
    }
  },
  {
    "name": "Auth - Forgot Password",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/forgot-password",
    "body": {
      "email": "alice@example.com"
    }
  },
  {
    "name": "Auth - Reset Password",
    "method": "POST",
    "url": "http://localhost:3000/api/auth/reset-password",
    "body": {
      "token": "<RESET_TOKEN>",
      "newPassword": "NewPassword123!"
    }
  },
